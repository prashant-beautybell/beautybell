# Slack Incoming Webhook — used by /api/contact and /api/newsletter
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Cloudflare Turnstile (https://dash.cloudflare.com → Turnstile)
# Client (Vite): site key
VITE_TURNSTILE_SITE_KEY=your_turnstile_site_key
# Server (Vercel + local dev): secret key — never expose in the browser
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# Local testing: Cloudflare always-pass test keys
# VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA
# TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
